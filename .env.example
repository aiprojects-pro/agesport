# MAPA DEL TALENTO AGESPORT - Variables de Entorno
# Copia este archivo a .env y configura con tus valores reales

# === BASE DE DATOS ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agesport_mapa_talento
DB_USER=postgres
DB_PASSWORD=tu_password_postgres_aqui

# === SEGURIDAD ===
JWT_SECRET=tu_super_secret_jwt_key_de_al_menos_32_caracteres
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_KEY=tu_clave_aes_de_exactamente_32_char

# Credenciales del administrador inicial (solo se usan en `npm run db:setup`)
ADMIN_INITIAL_EMAIL=admin@agesport.org
ADMIN_INITIAL_PASSWORD=cambia_esto_antes_de_db_setup

# === SERVIDOR ===
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# === CORS - URLs PERMITIDAS ===
# En desarrollo: http://localhost:3000,http://localhost:8080
# En producción: https://mapatalento.agesport.org,https://www.agesport.org
CORS_ORIGINS=https://mapatalento.agesport.org,https://www.agesport.org

# === SSL/TLS (para producción) ===
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem

# === EMAIL NOTIFICACIONES ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@agesport.org
EMAIL_PASS=tu_password_email
EMAIL_FROM="AGESPORT Mapa del Talento <noreply@agesport.org>"

# === MAPAS Y GEOCODING ===
MAPBOX_API_KEY=opcional_si_usas_mapbox_en_vez_de_nominatim

# === UPLOADS ===
UPLOADS_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# === RATE LIMITING ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_MESSAGE_MAX=20

# === LOGGING ===
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# === BACKUP ===
BACKUP_RETENTION_DAYS=30

# === MONITOREO ===
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

