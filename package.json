{
  "name": "agesport-mapa-talento",
  "version": "1.0.0",
  "description": "Plataforma de networking y talento para AGESPORT - Asociación Andaluza de Gestores del Deporte",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "deploy": "./deploy.sh",
    "db:setup": "node scripts/setup-database.js",
    "db:seed": "node scripts/seed-database.js",
    "db:migrate": "node scripts/migrate-database.js",
    "admin:create": "node scripts/create-admin.js",
    "health": "node scripts/health-check.js",
    "logs": "mkdir -p logs",
    "pm2:start": "npm run logs && pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs mapa-talento-agesport",
    "pm2:monit": "pm2 monit",
    "backup:db": "pg_dump $DB_NAME > backups/db-$(date +%Y%m%d-%H%M%S).sql",
    "test": "echo \"Tests not implemented yet\" && exit 0",
    "lint": "echo \"Linting not configured\" && exit 0"
  },
  "keywords": [
    "agesport",
    "deporte",
    "networking",
    "andalucia",
    "cluster",
    "talento",
    "b2b"
  ],
  "author": "AGESPORT - Asociación Andaluza de Gestores del Deporte",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agesport/mapa-talento"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
